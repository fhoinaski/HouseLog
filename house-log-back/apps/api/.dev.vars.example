# =============================================================================
# HouseLog — Cloudflare Workers (wrangler dev)
# =============================================================================
# Este arquivo configura os *secrets* do Worker durante o desenvolvimento local.
# O wrangler lê automaticamente um arquivo chamado .dev.vars na raiz do Worker.
#
#   cp apps/api/.dev.vars.example apps/api/.dev.vars
#
# ⚠️  NUNCA faça commit do .dev.vars — ele já está no .gitignore.
# Em produção, defina os secrets com:
#   wrangler secret put JWT_SECRET
# =============================================================================

# -----------------------------------------------------------------------------
# Segurança
# -----------------------------------------------------------------------------

# Chave secreta para assinar JWTs (HS256).
# Gere uma string aleatória forte (mín. 32 caracteres), por exemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-uma-chave-secreta-de-pelo-menos-32-caracteres

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Origens permitidas para requisições cross-origin.
# Use lista explícita: "*" não é aceito com credentials.
# "*" e ignorado porque a API envia credentials. Em production, lista vazia falha fechada.
CORS_ORIGINS=https://house-log.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------

# Valores possíveis: development | production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# R2 / arquivos publicos
# -----------------------------------------------------------------------------

# Base publica do bucket R2. Deve apontar para o dominio publico do bucket,
# sem barra no final. Trocar este valor muda a base usada nos novos uploads.
R2_PUBLIC_URL=https://pub-3ff8849243ae4ec2b6f124cf71160801.r2.dev

# Necessarios apenas para fluxos com URL preassinada.
# R2_ACCOUNT_ID=replace-with-cloudflare-account-id
# R2_BUCKET_NAME=houselog-assets-dev
# R2_ACCESS_KEY_ID=replace-with-dev-r2-access-key-id
# R2_SECRET_ACCESS_KEY=replace-with-dev-r2-secret-access-key

# -----------------------------------------------------------------------------
# Observabilidade
# -----------------------------------------------------------------------------
# DSN do projeto Sentry (opcional). Sem isso, o logger cai só para console.
# SENTRY_DSN=https://<publicKey>@<host>/<projectId>

# -----------------------------------------------------------------------------
# Web Push (VAPID)
# -----------------------------------------------------------------------------
# Gere com: npx web-push generate-vapid-keys
# O backend usa as três. O frontend precisa apenas de VAPID_PUBLIC_KEY
# (exposta via GET /api/v1/push/public-key).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@houselog.app

# -----------------------------------------------------------------------------
# Refresh tokens
# -----------------------------------------------------------------------------
# Dias até o refresh token expirar. Default: 30.
# REFRESH_TOKEN_TTL_DAYS=30

# -----------------------------------------------------------------------------
# Email transacional
# -----------------------------------------------------------------------------
# RESEND_API_KEY=replace-with-dev-resend-api-key

# -----------------------------------------------------------------------------
# Credenciais criptografadas
# -----------------------------------------------------------------------------
# Obrigatorio em production. Em dev, tambem prefira usar chave propria.
# CREDENTIALS_ENCRYPTION_KEY=replace-with-32-char-minimum-key
