{
  "name": "houselog-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "db:migrate": "wrangler d1 migrations apply houselog-db",
    "db:migrate:dev": "wrangler d1 migrations apply houselog-db-dev --env dev",
    "db:migrate:local": "wrangler d1 migrations apply houselog-db-dev --local",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "hono": "^4.6.14",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250409.0",
    "typescript": "^5",
    "wrangler": "^3.106.0"
  }
}
