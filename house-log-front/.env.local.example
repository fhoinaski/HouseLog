# =============================================================================
# HouseLog — Next.js Frontend
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores
#   cp .env.local.example .env.local

# -----------------------------------------------------------------------------
# API (Cloudflare Workers)
# -----------------------------------------------------------------------------

# URL base do backend — sem barra no final
# Desenvolvimento local (wrangler dev):
NEXT_PUBLIC_API_URL=http://localhost:8787/api/v1

# Produção (substitua pelo subdomínio real do seu Worker):
# NEXT_PUBLIC_API_URL=https://houselog-api.<seu-subdominio>.workers.dev/api/v1
